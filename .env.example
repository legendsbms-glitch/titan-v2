# TITAN v2.0 — Environment Variables
# Copy this to .env and fill in your keys

# FRED API (free) → https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI (free tier) → https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Twelve Data (free tier backup) → https://twelvedata.com/register
TWELVE_DATA_API_KEY=your_twelvedata_key_here

# App config
LOG_LEVEL=INFO
DB_PATH=db/titan.db
JOURNAL_PATH=journal/trades.json
