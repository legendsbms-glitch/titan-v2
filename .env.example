# ═══════════════════════════════════════════════════
# TITAN v2.0 — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Free API Keys ──────────────────────────────────
# FRED (Federal Reserve Economic Data) — FREE
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI — FREE (100 req/day)
# Register: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Twelve Data — FREE (800 req/day, optional backup)
# Register: https://twelvedata.com/register
TWELVE_DATA_API_KEY=your_twelvedata_key_here

# ── Telegram Alerts (optional) ─────────────────────
# Create a bot: https://t.me/BotFather → /newbot
# Get your chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Config ─────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=db/titan.db
JOURNAL_PATH=journal/trades.json
